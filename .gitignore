# Asegurarse de excluir archivos no deseados, por ejemplo, directorios .terraform, secrets, o claves privadas

# Local .terraform directories
.terraform/

# Llaves privadas SSH
*.pem

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Ignore the plan output of command: terraform plan -out=tfplan
*.tfplan
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc


# Archivos de reportes de Checkov
.checkov/
*.sarif
checkov_report.*

# Archivos de editores de código (VS Code, IntelliJ, etc.)
.vscode/
.idea/
*.swp

# Archivos del sistema operativo (Mac/Windows)
.DS_Store
Thumbs.db

# Archivos temporales generados en el pipeline
*.tf.plan
*tf.plan*
tfplan.json